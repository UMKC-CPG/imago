# See https://help.github.com/articles/ignoring-files for more
# about ignoring files.
#
# If you find yourself ignoring temporary files generated by your
# text editor or operating system, you probably want to add a
# global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore directories that will contain install databases,
# binaries, and jobs.
/bin
/share
/jobs
/distrib

# Ignore directories that will contain compiled object files.
/build/debug/*
/build/release/*

# Ignore any __pycache__ files (in the .imago directory).
__pycache__

# RC files in .imago/ are installed from src/scripts/ by
# "make install" and may be edited by the user after
# installation.  They must not be tracked here; the canonical
# versions live in src/scripts/.
.imago/*rc.py

# Ignore the external folder.  This is a uniform place to put
# all the things external to Imago but meant to be used with
# imago.
/external
/external/*
