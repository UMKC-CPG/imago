# See https://help.github.com/articles/ignoring-files for more
# about ignoring files.
#
# If you find yourself ignoring temporary files generated by your
# text editor or operating system, you probably want to add a
# global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore directories that will contain install databases,
# binaries, and jobs.
/bin
/share
/jobs
/distrib

# Ignore directories that will contain compiled object files.
/build/debug/*
/build/release/*

# Ignore any __pycache__ files (in the .imago directory).
__pycache__

# Ignore Fortran compiler module artifacts.  These are produced
# by gfortran/ifort as a by-product of compiling a module source
# file and live alongside the .o objects.  They must not be
# tracked because they are compiler- and version-specific and
# get rewritten on every build.
*.mod

# Ignore editor swap and backup files (vim, emacs).  These are
# transient and per-session; tracking them produces spurious
# untracked entries in git status during normal editing.
*.swp
*.swo
*~

# RC files in .imago/ are installed from src/scripts/ by
# "make install" and may be edited by the user after
# installation.  They must not be tracked here; the canonical
# versions live in src/scripts/.
.imago/*rc.py

# Ignore the external folder.  This is a uniform place to put
# all the things external to Imago but meant to be used with
# imago.
/external
/external/*

# Parsl writes a per-run "runinfo/" tree (logs, monitoring,
# task databases) into the working directory whenever a config
# is loaded.  The kaleidoscope tests load a thread-pool config,
# so this appears during a test run; it is transient runtime
# state and must not be tracked.
/runinfo
